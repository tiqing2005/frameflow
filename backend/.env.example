FRAMEFLOW_DATA_DIR=/data
FRAMEFLOW_DATABASE_URL=sqlite:////data/frameflow.db
FRAMEFLOW_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRAMEFLOW_MAX_UPLOAD_MB=100
FRAMEFLOW_MAX_SUBTITLE_CHARS=200000
FRAMEFLOW_READ_RATE_LIMIT_PER_MINUTE=240
FRAMEFLOW_WRITE_RATE_LIMIT_PER_MINUTE=60
FRAMEFLOW_AUTH_ENABLED=true
FRAMEFLOW_AUTH_LOCAL_SETUP_ENABLED=true
FRAMEFLOW_AUTH_USERNAME=admin
FRAMEFLOW_AUTH_DISPLAY_NAME=FrameFlow 管理员
FRAMEFLOW_AUTH_PASSWORD_HASH=
FRAMEFLOW_AUTH_PASSWORD=
FRAMEFLOW_AUTH_SESSION_HOURS=12
FRAMEFLOW_AUTH_COOKIE_SECURE=false
FRAMEFLOW_WORKER_CONCURRENCY=1
FRAMEFLOW_WORKER_POLL_SECONDS=0.75
FRAMEFLOW_STAGE_DELAY_SECONDS=0.18
FRAMEFLOW_JOB_LEASE_SECONDS=300
FRAMEFLOW_JOB_MAX_EXECUTION_SECONDS=1800
# Verified public path: local faster-whisper small/int8
# (`pip install -r requirements-asr-local.txt`).
FRAMEFLOW_ASR_PROVIDER=local
FRAMEFLOW_WHISPER_MODEL=small
FRAMEFLOW_WHISPER_DEVICE=cpu
FRAMEFLOW_WHISPER_COMPUTE_TYPE=int8
FRAMEFLOW_WHISPER_DOWNLOAD_ROOT=/data/models/whisper
HF_HOME=/data/models/huggingface
FRAMEFLOW_LOCAL_ASR_TIMEOUT=600
# Optional OpenAI-compatible speech-to-text. The key remains server-side.
OPENAI_API_KEY=
FRAMEFLOW_ASR_MODEL=gpt-4o-mini-transcribe
FRAMEFLOW_OPENAI_BASE_URL=https://api.openai.com/v1
FRAMEFLOW_ASR_TIMEOUT=120
# Optional DashScope Paraformer-v2. The adapter prepares 8 kbps / 75-second
# chunks and exposes only signed temporary source URLs.
DASHSCOPE_API_KEY=
FRAMEFLOW_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
FRAMEFLOW_ASR_PUBLIC_BASE_URL=
FRAMEFLOW_ASR_URL_SIGNING_SECRET=
FRAMEFLOW_DASHSCOPE_POLL_SECONDS=2
FRAMEFLOW_ASR_URL_TTL_SECONDS=1800
# Public semantic enhancement uses the `gemini` vendor label through an
# OpenAI-compatible /chat/completions gateway contract. DeepSeek remains replaceable.
LLM_PROVIDER=gemini
LLM_BASE_URL=https://llm-gateway.example.com/v1
LLM_API_KEY=
LLM_MODEL=gemini-3.1-flash-lite-preview
LLM_TIMEOUT=20
# Optional OpenAI-compatible visual tagging. `none` keeps media on this host.
VISION_PROVIDER=none
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=
VISION_MODEL=gpt-4o-mini
VISION_TIMEOUT=30
# Optional OpenAI-compatible text-to-image provider. This dedicated key stays
# server-side; leave the URL/key empty to disable the feature explicitly.
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
IMAGE_API_TIMEOUT=180
IMAGE_MAX_RESPONSE_MB=25
IMAGE_MAX_OUTPUT_MB=15
IMAGE_MAX_PIXELS=24000000
IMAGE_DRAFT_RETENTION_HOURS=72
IMAGE_DAILY_LIMIT=50
IMAGE_MAX_PENDING=5
EMBEDDING_PROVIDER=none
FRAMEFLOW_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
FRAMEFLOW_EMBEDDING_DEVICE=cpu
FRAMEFLOW_EMBEDDING_BASE_URL=https://api.openai.com/v1
FRAMEFLOW_EMBEDDING_API_KEY=
FRAMEFLOW_EMBEDDING_TIMEOUT=30
FRAMEFLOW_PREVIEW_TIMEOUT=300
FRAMEFLOW_PREVIEW_MAX_SECONDS=180
DEMO_MODE=false
