# 复制为 deploy/.env。不要提交真实密钥。
DOMAIN=frameflow.example.com
ACME_EMAIL=ops@example.com

# 可选整站 Basic Auth。默认未启用；启用步骤见 docs/DEPLOYMENT.md。
BASIC_AUTH_USER=frameflow
BASIC_AUTH_HASH=

# 镜像与持久化卷
FRAMEFLOW_TAG=latest
DATA_VOLUME_NAME=frameflow_data
CADDY_DATA_VOLUME_NAME=frameflow_caddy_data
CADDY_CONFIG_VOLUME_NAME=frameflow_caddy_config

# 应用
FRAMEFLOW_CORS_ORIGINS=https://frameflow.example.com
FRAMEFLOW_MAX_UPLOAD_MB=100
FRAMEFLOW_WORKER_POLL_SECONDS=0.75
FRAMEFLOW_STAGE_DELAY_SECONDS=0.18
FRAMEFLOW_JOB_LEASE_SECONDS=300
LOG_LEVEL=INFO

# 可选语义增强。默认 rules 不调用外部模型；启用 DeepSeek 时改为 deepseek 并填写密钥。
LLM_PROVIDER=rules
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT=20

# 语音识别：auto 在存在 OPENAI_API_KEY 时调用兼容接口，否则尝试本地 ASR。
# 默认镜像不含较重的本地模型依赖；需要离线 ASR 时设为 true 后重新构建。
INSTALL_LOCAL_ASR=false
FRAMEFLOW_ASR_PROVIDER=auto
FRAMEFLOW_ASR_MODEL=gpt-4o-mini-transcribe
FRAMEFLOW_OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
FRAMEFLOW_WHISPER_MODEL=tiny
FRAMEFLOW_WHISPER_DEVICE=cpu
FRAMEFLOW_WHISPER_COMPUTE_TYPE=int8
# Hugging Face / faster-whisper 模型缓存固定在持久化 /data 卷。
HF_HOME=/data/models/huggingface

# 预留给 OpenAI 兼容的图像生成服务。当前版本未把密钥下发到浏览器。
IMAGE_API_BASE_URL=https://image.example.com/v1
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
