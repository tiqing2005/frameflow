# 复制为 deploy/.env。不要提交真实密钥。
DOMAIN=frameflow.example.com
ACME_EMAIL=ops@example.com

# 受控 Demo 默认要求整站 Basic Auth。first-deploy 会交互生成哈希并启用。
# 只有在可信内网/外层已有强鉴权时，才显式设为 false 并执行 configure-auth.sh disable。
ENABLE_BASIC_AUTH=true
BASIC_AUTH_USER=frameflow
BASIC_AUTH_HASH=
CADDY_MAX_REQUEST_BODY=110MB

# 镜像与持久化卷
FRAMEFLOW_TAG=latest
DATA_VOLUME_NAME=frameflow_data
CADDY_DATA_VOLUME_NAME=frameflow_caddy_data
CADDY_CONFIG_VOLUME_NAME=frameflow_caddy_config

# 应用
FRAMEFLOW_CORS_ORIGINS=https://frameflow.example.com
FRAMEFLOW_MAX_UPLOAD_MB=100
FRAMEFLOW_READ_RATE_LIMIT_PER_MINUTE=240
FRAMEFLOW_WRITE_RATE_LIMIT_PER_MINUTE=60
FRAMEFLOW_WORKER_POLL_SECONDS=0.75
FRAMEFLOW_STAGE_DELAY_SECONDS=0.18
FRAMEFLOW_JOB_LEASE_SECONDS=300
FRAMEFLOW_JOB_MAX_EXECUTION_SECONDS=1800
FRAMEFLOW_PREVIEW_TIMEOUT=300
FRAMEFLOW_PREVIEW_MAX_SECONDS=180
FRAMEFLOW_MAX_SUBTITLE_CHARS=200000
# 生产/受控 Demo 默认关闭故障注入接口；仅本地演示需要时临时开启。
DEMO_MODE=false
LOG_LEVEL=INFO

# Compose 资源与日志上限；启用本地 ASR/Embedding 时按服务器容量提高内存。
FRAMEFLOW_CPUS=2.0
FRAMEFLOW_MEMORY_LIMIT=3g
FRAMEFLOW_PIDS_LIMIT=256
FRAMEFLOW_TMPFS_SIZE=256m
FRAMEFLOW_LOG_MAX_SIZE=10m
FRAMEFLOW_LOG_MAX_FILES=3
CADDY_CPUS=0.50
CADDY_MEMORY_LIMIT=256m
CADDY_PIDS_LIMIT=128
CADDY_LOG_MAX_SIZE=10m
CADDY_LOG_MAX_FILES=3

# 可选语义增强。默认 rules 不调用外部模型；启用 DeepSeek 时改为 deepseek 并填写密钥。
LLM_PROVIDER=rules
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT=20

# 语音识别：auto 在存在 OPENAI_API_KEY 时调用兼容接口，否则尝试本地 ASR。
# 默认镜像不含较重的本地模型依赖；需要离线 ASR 时设为 true 后重新构建。
INSTALL_LOCAL_ASR=false
FRAMEFLOW_ASR_PROVIDER=auto
FRAMEFLOW_ASR_MODEL=gpt-4o-mini-transcribe
FRAMEFLOW_ASR_TIMEOUT=120
FRAMEFLOW_LOCAL_ASR_TIMEOUT=600
FRAMEFLOW_OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
FRAMEFLOW_WHISPER_MODEL=tiny
FRAMEFLOW_WHISPER_DEVICE=cpu
FRAMEFLOW_WHISPER_COMPUTE_TYPE=int8
# Hugging Face / faster-whisper 模型缓存固定在持久化 /data 卷。
HF_HOME=/data/models/huggingface

# 混合排序语义向量。默认 auto：本地依赖不可用时可回退远程或字符 n-gram。
# 纯本地向量需设 INSTALL_LOCAL_EMBEDDINGS=true 并重新构建镜像。
INSTALL_LOCAL_EMBEDDINGS=false
EMBEDDING_PROVIDER=auto
FRAMEFLOW_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
FRAMEFLOW_EMBEDDING_BASE_URL=https://api.openai.com/v1
FRAMEFLOW_EMBEDDING_API_KEY=
FRAMEFLOW_EMBEDDING_TIMEOUT=30
FRAMEFLOW_EMBEDDING_DEVICE=cpu

# 预留给 OpenAI 兼容的图像生成服务。当前版本未把密钥下发到浏览器。
IMAGE_API_BASE_URL=https://image.example.com/v1
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
