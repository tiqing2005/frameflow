# Runtime
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/frameflow.db
DEMO_MODE=true
CORS_ORIGINS=http://localhost:5173

# Worker
WORKER_POLL_SECONDS=0.5
JOB_LEASE_SECONDS=60
JOB_STAGE_DELAY_MS=350
MAX_UPLOAD_MB=100

# Real local speech recognition (optional dependency: faster-whisper)
ASR_PROVIDER=local
ASR_MODEL=tiny
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_DOWNLOAD_ROOT=./data/models

# Optional server-side semantic enhancement. Never use VITE_ for secrets.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

