# FrameFlow server-side configuration. Copy to .env; never commit real keys.
APP_ENV=development
FRAMEFLOW_DATA_DIR=./data
FRAMEFLOW_DATABASE_URL=sqlite:///./data/frameflow.db
FRAMEFLOW_CORS_ORIGINS=http://localhost:5173
FRAMEFLOW_MAX_UPLOAD_MB=100
FRAMEFLOW_MAX_SUBTITLE_CHARS=200000
FRAMEFLOW_READ_RATE_LIMIT_PER_MINUTE=240
FRAMEFLOW_WRITE_RATE_LIMIT_PER_MINUTE=60

# Application login is enabled by default. On a fresh local database, the web
# page lets you create the first administrator once from localhost. For managed
# deployment, disable local setup and provide a hash (never commit the password):
#   cd backend
#   python -c "from app.auth import hash_password; import getpass; print(hash_password(getpass.getpass()))"
FRAMEFLOW_AUTH_ENABLED=true
FRAMEFLOW_AUTH_LOCAL_SETUP_ENABLED=true
FRAMEFLOW_AUTH_USERNAME=admin
FRAMEFLOW_AUTH_DISPLAY_NAME=FrameFlow 管理员
FRAMEFLOW_AUTH_PASSWORD_HASH=
# Plain password is accepted only for local development; production should use the hash above.
FRAMEFLOW_AUTH_PASSWORD=
FRAMEFLOW_AUTH_SESSION_HOURS=12
FRAMEFLOW_AUTH_COOKIE_SECURE=false

# Durable worker
FRAMEFLOW_WORKER_CONCURRENCY=2
FRAMEFLOW_WORKER_POLL_SECONDS=0.5
FRAMEFLOW_JOB_LEASE_SECONDS=60
FRAMEFLOW_JOB_MAX_EXECUTION_SECONDS=1800
FRAMEFLOW_STAGE_DELAY_SECONDS=0.18

# Real local speech recognition. `base` is the recommended quality/speed balance.
FRAMEFLOW_ASR_PROVIDER=local
FRAMEFLOW_WHISPER_MODEL=base
FRAMEFLOW_WHISPER_DEVICE=cpu
FRAMEFLOW_WHISPER_COMPUTE_TYPE=int8
FRAMEFLOW_LOCAL_ASR_TIMEOUT=600

# Optional OpenAI-compatible speech API instead of local faster-whisper.
OPENAI_API_KEY=
FRAMEFLOW_OPENAI_BASE_URL=https://api.openai.com/v1
FRAMEFLOW_ASR_MODEL=gpt-4o-mini-transcribe
FRAMEFLOW_ASR_TIMEOUT=120

# Optional Alibaba Model Studio / DashScope Paraformer file transcription.
# The public base URL must be the HTTPS origin serving this FrameFlow instance.
DASHSCOPE_API_KEY=
FRAMEFLOW_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
FRAMEFLOW_ASR_PUBLIC_BASE_URL=
FRAMEFLOW_ASR_URL_SIGNING_SECRET=
FRAMEFLOW_DASHSCOPE_POLL_SECONDS=2
FRAMEFLOW_ASR_URL_TTL_SECONDS=1800

# Optional semantic segmentation enhancement. DeepSeek V4 Pro is supported
# through the OpenAI-compatible /chat/completions contract.
LLM_PROVIDER=rules
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT=30

# Optional semantic similarity channel for the hybrid ranker. The 0.55 weight
# feeds the "tfidf_score" slot; with an embedding provider it carries true
# semantic cosine, otherwise it falls back to character n-gram TF-IDF.
#   auto            -> local BGE if sentence-transformers installed, else remote if key, else char-ngram
#   local           -> require local BGE (install requirements-embeddings-local.txt)
#   openai|openai-compatible -> remote /embeddings endpoint
#   none            -> force char-ngram fallback (zero dependency)
EMBEDDING_PROVIDER=auto
FRAMEFLOW_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
FRAMEFLOW_EMBEDDING_DEVICE=cpu
# Remote endpoint (only used when provider is openai/openai-compatible or auto with a key):
FRAMEFLOW_EMBEDDING_BASE_URL=https://api.openai.com/v1
FRAMEFLOW_EMBEDDING_API_KEY=
FRAMEFLOW_EMBEDDING_TIMEOUT=30

# Preview video rendering (ffmpeg, H.264 MP4).
FRAMEFLOW_PREVIEW_TIMEOUT=300
FRAMEFLOW_PREVIEW_MAX_SECONDS=180

# Demo-only fault injection controls remain server-side.
DEMO_MODE=false
